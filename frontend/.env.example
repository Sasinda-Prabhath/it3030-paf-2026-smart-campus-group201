# ========================================
# SMART CAMPUS FRONTEND - ENVIRONMENT CONFIGURATION
# ========================================
# 
# IMPORTANT: Frontend .env files can contain non-sensitive values
# They are exposed in the browser, so do NOT add secrets here!
# 
# Setup Instructions:
# 1. Copy this file: cp .env.example .env
# 2. Update values if needed for your environment
#
# ========================================

# Frontend Application URL
VITE_FRONTEND_URL=http://localhost:5173

# Backend API Configuration
VITE_API_BASE_URL=http://localhost:8080