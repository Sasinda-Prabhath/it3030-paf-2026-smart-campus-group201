# ========================================
# SMART CAMPUS BACKEND - ENVIRONMENT CONFIGURATION
# ========================================
# 
# IMPORTANT: This is a template file (.example)
# DO NOT add real secrets to .env.example!
# 
# Setup Instructions:
# 1. Copy this file: cp .env.example .env
# 2. Edit .env and add your actual values
# 3. .env is gitignored and will NOT be committed
#
# ========================================

# Database Configuration
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/smartcampus
SPRING_DATASOURCE_USERNAME=your_username
SPRING_DATASOURCE_PASSWORD=your_secure_password_here

# Frontend Configuration
FRONTEND_URL=http://localhost:3000

# Google OAuth2 Configuration (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8080/login/oauth2/code/google